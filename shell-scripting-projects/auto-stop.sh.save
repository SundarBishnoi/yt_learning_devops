#!/bin/bash

# Clear system execution paths so cron can run tools reliably
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# Print current timestamp alongside the log message
TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S")

# Check: Is your local VS Code actively talking to the server right now?
# This looks for established SSH traffic streams on port 22
if ss -tna | grep :22 | grep -q ESTAB; then
    VSCODE_CONNECTED=1
else
    VSCODE_CONNECTED=0
fi

# Shut down if no active connection stream is detected
if [ $VSCODE_CONNECTED -eq 0 ]; then
    echo "[$TIMESTAMP] No active VS Code network connection found. Shutting down." >> /var/log/auto-stop.log
    /sbin/shutdown -h now
else
    echo "[$TIMESTAMP] VS Code connection is live. Keeping instance awake." >> /var/log/auto-stop.log
    
    # 🧹 LOG HOUSEKEEPING: Keep only the last 50 lines and delete all older logs
    if [ -f /var/log/auto-stop.log ]; then
        CLEANED_LOGS=$(tail -n 100 /var/log/auto-stop.log)
        echo "$CLEANED_LOGS" > /var/log/auto-stop.log
    fi
fi

